# Copy this file to .env and fill in your values
# cp .env.example .env

# Database type: mariadb (default) or postgresql
DB_TYPE=mariadb

# Full JDBC URL (for production compose)
# MariaDB:    jdbc:mariadb://host:3306/tuensso
# PostgreSQL: jdbc:postgresql://host:5432/tuensso
DB_URL=jdbc:mariadb://192.168.1.100:3306/tuensso

DB_NAME=tuensso
DB_USER=tuensso
DB_PASSWORD=change-me-to-a-strong-password

# Public URL where TuenSSO is accessible
TUENSSO_ISSUER=https://sso.yourdomain.com
